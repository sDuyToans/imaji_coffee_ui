<!doctype html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <title>{{ htmlWebpackPlugin.options.title }}</title>
    <link rel="stylesheet" href="{{htmlWebpackPlugin.options.host}}/styles/styles.css">
</head>
<body>

<div>
    <h1>Dratuti</h1>


    <!--First example-->
    <h2 class="heading">The default</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2, 2.1],
	containerWidth: 530,
	containerPadding: 5,
	boxSpacing: 5,
	targetRowHeight: 160,
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="default"></div>


    <!--Second example-->
    <h2 class="heading">Container Padding Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2, 2.1],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: 5,
	targetRowHeight: 160,
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="container-padding"></div>


    <!--Third example-->
    <h2 class="heading">Uneven Container Padding Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2, 2.1],
	containerWidth: 530,
	containerPadding: {
            top: 25,
            right: 10,
            left: 100,
            bottom: 25,
        },
	boxSpacing: 5,
	targetRowHeight: 160,
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="uneven-container-padding"></div>


    <!--Fourth example-->
    <h2 class="heading">Box Spacing Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2, 2.1],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: {
            horizontal: 2,
            vertical: 15
        },
	targetRowHeight: 160,
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="box-spacing"></div>


    <!--Fifth example-->
    <h2 class="heading">Target Row Height Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2.2, 1.5, 0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2.2],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: 5,
	targetRowHeight: 50,
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="target-row-height"></div>


    <!--Sixth example-->
    <h2 class="heading">Force Aspect Ratio Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2.2, 1.5],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: 5,
	targetRowHeight: 160,
    forceAspectRatio: 1
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="force-aspect-ratio"></div>


    <!--Seventh example-->
    <h2 class="heading">Don't show widows Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2.2, 1.5],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: 5,
	targetRowHeight: 160,
    showWidows: false
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>
    <div id="widow"></div>


    <!--Eighth example-->
    <h2 class="heading">Full Width Breakout Row Config</h2>
    <p><pre class="implementation"><code>const defaultOptions = {
	boxes: [0.5, 1.5, 1, 1.8, 0.4, 0.7, 0.9, 1.1, 1.7, 2.2, 1.5],
	containerWidth: 530,
	containerPadding: 50,
	boxSpacing: 5,
	targetRowHeight: 160,
    fullWidthBreakoutRowCadence: 2
};
const boxClass = 'justified-layout-box--custom';
const containerClass = 'justified-layout-container--custom';</code></pre></p>

    <div id="breakout-row"></div>
</div>
<script src="{{htmlWebpackPlugin.options.host}}/application.js"></script>
</body>
</html>